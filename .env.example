# Copy to .env and set your key.
# Groq API key: https://console.groq.com/keys
GROQ_API_KEY=

# Optional: vision model (see https://console.groq.com/docs/vision)
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional: max completion tokens for vision chat (default 4096; max 8192 for Groq vision models)
# CHAT_VISION_MAX_TOKENS=8192

# Optional: server port
# PORT=3000
