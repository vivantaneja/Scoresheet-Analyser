# Copy to .env and set your key.
# Vision / extraction API key (see SETUP.md).
GROQ_API_KEY=

# Random string, 32+ characters  -  signs the anonymous browser session cookie (required if NODE_ENV=production).
# On Vercel, set this in the project env (do not commit real values).
# SESSION_SECRET=

# Public hosting on Vercel: Upstash Redis REST (free tier) for per-user JSON. Optional locally  -  without it, data is stored under .user-data/
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: default sheet layout when the upload form does not send sheetVariant (ireland | fiba).
# SHEET_DEFAULT_VARIANT=ireland

# Optional: vision model ID
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Upload size: multipart file limit in MB (default 20 local, 4 on Vercel). Vercel caps the whole POST body ~4.5MB  -  larger uploads need another host or Blob + URL flow.
# UPLOAD_MAX_FILE_MB=20
# Max base64 data URL size to the vision API in MB (default 3.5). Raw image should be smaller  -  base64 expands ~33%.
# VISION_MAX_DATA_URL_MB=3.5

# Optional: max completion tokens for vision JSON output (default 8192). Lower (e.g. 4096) only if the API rejects the request.
# Hard ceiling (default 8192, max 16384 if your provider/model allows): GROQ_MAX_COMPLETION_TOKENS_CAP=8192
# CHAT_VISION_MAX_TOKENS=8192

# Optional: stricter distributed upload limits (uses same Upstash Redis as data). Defaults: 20 per hour per IP+session.
# UPLOAD_RATELIMIT_MAX=20
# UPLOAD_RATELIMIT_WINDOW=1 h

# Optional: Cloudflare Turnstile  -  set BOTH site key (public) and secret (server only). https://dash.cloudflare.com/?to=/:account/turnstile
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Optional: server port
# PORT=3000
# Listen address: default 0.0.0.0 (reachable from phone on same Wi‑Fi). Use 127.0.0.1 for localhost-only.
# HOST=0.0.0.0
