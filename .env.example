# Copy this file to .env and add your key.
# Get an API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: primary model and fallbacks (comma-separated). See server.js getCandidateModels().
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_MODEL_FALLBACKS=gemini-2.0-flash-lite,gemini-2.5-flash

# Default 16384. Large scoresheets need room for runningScoreEvents + players.
# GEMINI_MAX_OUTPUT_TOKENS=16384

# Set to 1 to enforce JSON Schema strictly. Can make lite models return sparse JSON (many zeros).
# GEMINI_RESPONSE_SCHEMA=0
