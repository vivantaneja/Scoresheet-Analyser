{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["*.html", "assets/**", "schema.json", "schema-fiba.json", "extraction-prompt.txt", "extraction-prompt-fiba.txt"]
      }
    }
  ],
  "routes": [{"src": "/(.*)", "dest": "/server.js"}]
}
